# Banking Financial API - Environment Variables
# Copy this file to .env and update values for your environment

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/banking
DB_USERNAME=banking_user
DB_PASSWORD=your_secure_password_here

# JWT Configuration
# IMPORTANT: Generate a secure secret with at least 256 bits (32+ characters)
# You can generate one with: openssl rand -base64 32
JWT_SECRET=change-me-in-production-minimum-256-bits-required

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# Rate Limiting (optional overrides)
# RATE_LIMIT_GENERAL_CAPACITY=100
# RATE_LIMIT_AUTH_CAPACITY=10
